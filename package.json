{
  "name": "finanzverwaltung-pro",
  "version": "1.0.1",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "publish": "electron-builder --win --x64 --publish always"
  },
  "build": {
    "appId": "de.finanzverwaltung.pro",
    "productName": "Finanzverwaltung Pro",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Marco-Conrad-00",
        "repo": "FinanzverwaltungPro-"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Finanzverwaltung Pro",
      "installerLanguages": [
        "de_DE"
      ],
      "language": "1031"
    },
    "files": [
      "src/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  }
}
